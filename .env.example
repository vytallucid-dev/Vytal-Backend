NODE_ENV=
PORT=
DATABASE_URL=
DIRECT_URL=
DATABASE_PASSWORD=
JWT_SECRET=
REDIS_URL=
# Supabase project URL, e.g. https://<project-ref>.supabase.co
# Auth middleware derives the JWT issuer + JWKS discovery endpoint from this.
SUPABASE_URL=
# Resend transactional email (alert delivery drain).
#   RESEND_API_KEY — Resend API key.
#   RESEND_FROM    — verified Vytal sending address, e.g. "Vytal Alerts <alerts@vytal.in>"
#                    (DNS/SPF/DKIM for the domain is set up separately by the operator).
RESEND_API_KEY=
RESEND_FROM=
# Base URL of the frontend app — used to build absolute links in alert emails
# (stock page + "manage your alerts"). No trailing slash. Falls back to
# https://app.vytal.in when unset.
APP_BASE_URL=