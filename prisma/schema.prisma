  // ── Revenue Account (Premium) ──
  grossPremiumsWritten         Decimal? @map("gross_premiums_written") @db.Decimal(18, 2)
  netPremiumWritten            Decimal? @map("net_premium_written") @db.Decimal(18, 2)
