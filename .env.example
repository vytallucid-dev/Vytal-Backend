NODE_ENV=
PORT=
DATABASE_URL=
DIRECT_URL=
DATABASE_PASSWORD=
JWT_SECRET=
REDIS_URL=
# Supabase project URL, e.g. https://<project-ref>.supabase.co
# Auth middleware derives the JWT issuer + JWKS discovery endpoint from this.
SUPABASE_URL=
# Resend transactional email (alert delivery drain).
#   RESEND_API_KEY — Resend API key.
#   RESEND_FROM    — verified Vytal sending address, e.g. "Vytal Alerts <alerts@vytal.in>"
#                    (DNS/SPF/DKIM for the domain is set up separately by the operator).
RESEND_API_KEY=
RESEND_FROM=
# Base URL of the frontend app — used to build absolute links in alert emails
# (stock page + "manage your alerts"). No trailing slash. Falls back to
# https://app.vytal.in when unset.
APP_BASE_URL=
# ── AI provider adapter (src/ai/) ──────────────────────────────────────────
# Provider-agnostic AI layer. Selection + secrets are read LAZILY by the adapter
# (src/ai/registry.ts + adapters/*) — an absent key fails closed only when the
# provider is actually invoked, never at boot.
#   AI_PROVIDER    — which adapter to use: "gemini" | "mock". Defaults to "mock"
#                    (no key, no network, never bills) when unset.
#                    ⚠ MUST BE "gemini" FOR ANY AI SURFACE TO PRODUCE REAL TEXT. "mock" is the safe
#                    BOOT default, not a working configuration: the stub returns placeholder text
#                    ("[mock] …"), and src/ai/explain/stock-health.ts REFUSES to cache it and returns
#                    state:"mock" rather than "ok" — so a forgotten setting shows up as an obviously
#                    non-answer instead of silently poisoning the explanation cache with stub prose.
#                    Set this to "gemini" (with GEMINI_API_KEY below) in any environment that is
#                    meant to serve users.
#   AI_MODEL       — default model id the Gemini adapter uses when a caller does not
#                    pass one. Intended: "gemini-3.5-flash". Leave blank to use the
#                    adapter's pinned default (src/ai/adapters/gemini.ts).
#   GEMINI_API_KEY — Google Gen AI (Gemini) API key. Required ONLY when
#                    AI_PROVIDER=gemini; read lazily in the adapter constructor.
AI_PROVIDER=gemini
AI_MODEL=
GEMINI_API_KEY=
# ── AI quota guard (src/ai/quota.ts) ───────────────────────────────────────
# Cost-safety gate consulted before every Gemini call. Budget is PER MODEL (each model has its
# own free-tier RPD); the ceiling is looked up by model id. Read lazily by quota.ts.
#   AI_BUDGET_FLASH_LITE — max gemini-3.5-flash-lite CALLS per day. Real free-tier RPD for
#                          gemini-3.5-flash-lite is 500; 480 leaves headroom. Confirmed via
#                          AI Studio dashboard.
#   AI_BUDGET_FLASH      — max gemini-3.5-flash CALLS per day. Real free-tier RPD for
#                          gemini-3.5-flash is only 20. Confirmed via AI Studio dashboard. This
#                          is why we prototype on Flash-Lite. (Unlisted models gate at 18.)
#   AI_QUOTA_TIMEZONE    — Google's quota reset zone (the "day" boundary). Flips to
#                          irrelevant on paid rolling-window billing.
#   AI_QUOTA_ENABLED     — kill switch; off ONLY when exactly "false" (allows all calls
#                          without touching the DB).
AI_BUDGET_FLASH_LITE=480
AI_BUDGET_FLASH=18
AI_QUOTA_TIMEZONE=America/Los_Angeles
AI_QUOTA_ENABLED=true