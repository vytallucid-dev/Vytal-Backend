  incomeFromInvestments Decimal? @map("income_from_investments") @db.Decimal(18, 2)
  otherIncome           Decimal? @map("other_income") @db.Decimal(18, 2)
  totalRevenue          Decimal? @map("total_revenue") @db.Decimal(18, 2)

  // ── Claims ──
  claimsPaid                    Decimal? @map("claims_paid") @db.Decimal(18, 2)
  changeInOutstandingClaims     Decimal? @map("change_in_outstanding_claims") @db.Decimal(18, 2)
  incurredClaims                Decimal? @map("incurred_claims") @db.Decimal(18, 2)
  reinsuranceRecoveriesOnClaims Decimal? @map("reinsurance_recoveries_on_claims") @db.Decimal(18, 2)

  // ── Commission ──
  commissionPaid                    Decimal? @map("commission_paid") @db.Decimal(18, 2)
  commissionReceivedFromReinsurance Decimal? @map("commission_received_from_reinsurance") @db.Decimal(18, 2)
  netCommission                     Decimal? @map("net_commission") @db.Decimal(18, 2)

  // ── Operating expenses ──
  employeesRemuneration                    Decimal? @map("employees_remuneration") @db.Decimal(18, 2)
  rentRatesAndTaxes                        Decimal? @map("rent_rates_and_taxes") @db.Decimal(18, 2)
  legalAndProfessionalCharges              Decimal? @map("legal_and_professional_charges") @db.Decimal(18, 2)
  advertisementAndPublicity                Decimal? @map("advertisement_and_publicity") @db.Decimal(18, 2)
  totalOperatingExpensesRelatedToInsurance Decimal? @map("total_operating_expenses_related_to_insurance") @db.Decimal(18, 2)

  // ── Underwriting result ──
  premiumDeficiency        Decimal? @map("premium_deficiency") @db.Decimal(18, 2)
  underwritingProfitOrLoss Decimal? @map("underwriting_profit_or_loss") @db.Decimal(18, 2)

  // ── P&L (Shareholders' account) ──
  profitBeforeTax Decimal? @map("profit_before_tax") @db.Decimal(18, 2)
  tax             Decimal? @db.Decimal(18, 2)
  netProfit       Decimal? @map("net_profit") @db.Decimal(18, 2)

  // ── BS (year-end) ──
  shareCapital           Decimal? @map("share_capital") @db.Decimal(18, 2)
  reservesAndSurplus     Decimal? @map("reserves_and_surplus") @db.Decimal(18, 2)
  fairValueChangeAccount Decimal? @map("fair_value_change_account") @db.Decimal(18, 2)
  borrowings             Decimal? @db.Decimal(18, 2)
  totalSourcesOfFunds    Decimal? @map("total_sources_of_funds") @db.Decimal(18, 2)

  investments             Decimal? @db.Decimal(18, 2)
  loansApplicationOfFunds Decimal? @map("loans_application_of_funds") @db.Decimal(18, 2)
  fixedAssets             Decimal? @map("fixed_assets") @db.Decimal(18, 2)
  cashAndBankBalances     Decimal? @map("cash_and_bank_balances") @db.Decimal(18, 2)
  advancesAndOtherAssets  Decimal? @map("advances_and_other_assets") @db.Decimal(18, 2)
  currentLiabilities      Decimal? @map("current_liabilities") @db.Decimal(18, 2)
  provisions              Decimal? @db.Decimal(18, 2)
  totalApplicationOfFunds Decimal? @map("total_application_of_funds") @db.Decimal(18, 2)
  totalAssets             Decimal? @map("total_assets") @db.Decimal(18, 2)

  // ── Disclosed insurance-specific ratios ──
  combinedRatio             Decimal? @map("combined_ratio") @db.Decimal(8, 6)
  incurredClaimRatio        Decimal? @map("incurred_claim_ratio") @db.Decimal(8, 6) // = loss ratio
  expensesOfManagementRatio Decimal? @map("expenses_of_management_ratio") @db.Decimal(8, 6)
  netRetentionRatio         Decimal? @map("net_retention_ratio") @db.Decimal(8, 6)
  solvencyRatio             Decimal? @map("solvency_ratio") @db.Decimal(8, 4)

  // ── Per-Share ──
  basicEps            Decimal? @map("basic_eps") @db.Decimal(10, 4)
  dilutedEps          Decimal? @map("diluted_eps") @db.Decimal(10, 4)
  faceValueShare      Decimal? @map("face_value_share") @db.Decimal(10, 4)
  paidUpEquityCapital Decimal? @map("paid_up_equity_capital") @db.Decimal(18, 2)

  // ── Derived ──
  netWorth              Decimal? @map("net_worth") @db.Decimal(18, 2)
  bookValuePerShare     Decimal? @map("book_value_per_share") @db.Decimal(10, 4)
  roe                   Decimal? @db.Decimal(8, 6)
  netUnderwritingMargin Decimal? @map("net_underwriting_margin") @db.Decimal(8, 6) // (1 - combinedRatio)

  gpwGrowthYoy Decimal? @map("gpw_growth_yoy") @db.Decimal(8, 4)
  patGrowthYoy Decimal? @map("pat_growth_yoy") @db.Decimal(8, 4)

  extraMetrics Json? @map("extra_metrics")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  stock     Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, fiscalYear])
  @@index([stockId, fiscalYear])
  @@map("general_insurance_fundamentals")
}

