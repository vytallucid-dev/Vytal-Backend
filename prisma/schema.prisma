// ═══════════════════════════════════════════════════════════════════════════
// VYTAL HEALTH SCORE — SCORING-PERSISTENCE LAYER
// Implements docs/scoring-schema-design.md (LOCKED) + the final rulings.
// ADDITIVE ONLY. Reads the input tables, never modifies them.
//
// Layer-wide conventions (match the append-only exemplars DailyPrice /
// ShareholdingPattern):
//   • uuid PKs; @map/@@map snake_case; `score_` table-name prefix.
//   • APPEND-ONLY: `createdAt` only, NEVER `updatedAt`. A correction/recompute
//     is a NEW row — rows are never updated in place. An updatedAt column in
//     this layer would itself be a bug.
//   • peerGroupId / barPath / sectorId are stored as PLAIN strings captured at
//     stamp time (frozen — a later PG reshuffle must not rewrite history), NOT
//     live FKs. This matches the PeerGroupComputationLog precedent and avoids
//     touching the off-limits PeerGroup/Sector tables.
//   • Decimal policy: 0–100 scores / weights / percentages → Decimal(8,4);
//     native metric magnitudes (raw values, bar thresholds, μ/σ, ₹Cr flows,
//     caps) → Decimal(18,4) to span both ratio- and crore-scale metrics.
//
// CADENCE (the rule that shapes the keys — final ruling, overrides the doc's
// snapshot-owns-pillars draft):
//   • A pillar (PillarScore + its leaves) is written ONLY when that pillar's
//     inputs change. It is stock-grain and versioned, NOT a per-snapshot child.
//   • A ScoreSnapshot REFERENCES the four in-force pillar rows by FK
//     (foundation/momentum/market/ownershipPillarId). It does NOT own a fresh
//     copy of all four pillars each recompute.
//   • Foundation cannot write a duplicate daily row: enforced structurally by
//     PillarScore @@unique([stockId, pillar, inputsFingerprint]). On a
//     price-only day Foundation's fingerprint is unchanged → the insert is a
//     no-op and the new snapshot REUSES the existing Foundation pillar id.
// ═══════════════════════════════════════════════════════════════════════════

// ─────────────────────────────────────────────────────────────
// GROUP 1 — VERSIONING / REPRODUCIBILITY SPINE
// The four decoupled version axes + the run that stamps every score.
// ─────────────────────────────────────────────────────────────

enum ScoringRunType {
  quarterly
  live
}

enum ScoringTriggerType {
  scheduled
  post_ingest
  manual_api
}

enum ScoringRunStatus {
  running
  success
  partial
  failed
}

enum BarDirection {
  higher_better
  lower_better
}

// Layer A/B/C derivation evidence tier (kept lowercase per repo enum style).
enum DerivationLayer {
  layer_a
  layer_b
  layer_c
}

// Universal Market sub-components (CN-1): A=positioning (A1 52w-range, A2 3y-range),
// B=trend (B1 vs-200DMA, B2 4Q HH/HL, B3 recent-move), C=relative (C1 vs sector),
// D=risk (D1 vol-ratio). Replaced the Phase-4 4-component set on the universal-Market build.
enum MarketSubComponent {
  A1
  A2
  B1
  B2
  B3
  C1
  D1
}

// The §5 category a Market sub-component rolls into (equal-by-category weighting).
enum MarketCategory {
  A
  B
  C
  D
}

// §5.3.1 / §5.4.1 anchor-lift rule that fired when computing the L2 anchor.
enum AnchorLiftRule {
  rule_5_3_1
  rule_5_4_1
}

// The §-numbered methodology in force. Bumped only when the methodology changes.
model ScoringSpecVersion {
  id            String   @id @default(uuid())
  version       String // e.g. "2026.1"
  effectiveFrom DateTime @map("effective_from") @db.Date
  notes         String?
  checksum      String? // checksum of the spec doc
  createdAt     DateTime @default(now()) @map("created_at")

  runs                  ScoringRun[]
  metricBarSets         MetricBarSet[]
  ownershipFlowBandSets OwnershipFlowBandSet[]
  snapshots             ScoreSnapshot[]
  pillarScores          PillarScore[]
  sectorHealthCaches    SectorHealthCache[]

  @@unique([version])
  @@map("score_spec_versions")
}

// One computation run. The computationRunId every score row FKs back to.
model ScoringRun {
  id               String             @id @default(uuid())
  runType          ScoringRunType     @map("run_type")
  triggerType      ScoringTriggerType @map("trigger_type")
  specVersionId    String             @map("spec_version_id")
  asOfDate         DateTime           @map("as_of_date") @db.Date
  status           ScoringRunStatus   @default(running)
  startedAt        DateTime?          @map("started_at")
  finishedAt       DateTime?          @map("finished_at")
  durationMs       Int?               @map("duration_ms")
  stocksScored     Int                @default(0) @map("stocks_scored")
  stocksSuppressed Int                @default(0) @map("stocks_suppressed")
  error            String?
  createdAt        DateTime           @default(now()) @map("created_at")

  specVersion        ScoringSpecVersion  @relation(fields: [specVersionId], references: [id])
  snapshots          ScoreSnapshot[]
  pillarScores       PillarScore[]
  peerStats          PeerStatsSnapshot[]
  sectorHealthCaches SectorHealthCache[]

  @@index([runType, asOfDate])
  @@map("score_runs")
}

// Versioned 5-threshold L1 bar set, per (barPath, metric, version).
// 5 thresholds are HOT relational columns. Score rows reference the exact
// version in force at their snapshot date; a re-derivation writes a NEW
// version and never overwrites.
//
// BANKING UNIFIED BARS (final ruling 8): inheritance is BAR-SET-ONLY.
// `inheritsFromPeerGroupId` lets PG6 inherit PG5's Lens-1 metric bar-set.
// This is the ONLY inheritance pointer in the whole scoring layer — peer-stats
// (PeerStatsSnapshot) deliberately carry NO such pointer, so it is structurally
// impossible for PG6 to pull PG5's PeerStatsSnapshot through this link.
model MetricBarSet {
  id                      String          @id @default(uuid())
  barPath                 String          @map("bar_path") // a peerGroupId, or a logical path
  metricKey               String          @map("metric_key")
  version                 Int
  direction               BarDirection
  excellent               Decimal         @db.Decimal(18, 4)
  good                    Decimal         @db.Decimal(18, 4)
  acceptable              Decimal         @db.Decimal(18, 4)
  concerning              Decimal         @db.Decimal(18, 4)
  distress                Decimal         @db.Decimal(18, 4)
  inForceFrom             DateTime        @map("in_force_from") @db.Date
  specVersionId           String          @map("spec_version_id")
  provenanceId            String          @map("provenance_id")
  derivationLayer         DerivationLayer @map("derivation_layer")
  inheritsFromPeerGroupId String?         @map("inherits_from_peer_group_id") // ruling 8: bar-set only
  createdAt               DateTime        @default(now()) @map("created_at")

  specVersion  ScoringSpecVersion @relation(fields: [specVersionId], references: [id])
  provenance   BarProvenance      @relation(fields: [provenanceId], references: [id])
  metricScores MetricScore[]

  @@unique([barPath, metricKey, version])
  @@index([barPath, metricKey, inForceFrom(sort: Desc)]) // "bar version in force at snapshot date"
  @@map("score_metric_bar_sets")
}

// COLD Layer A/B/C derivation evidence — referenced by a bar set, NOT
// normalised per-observation. Not indexed for hot reads.
model BarProvenance {
  id              String          @id @default(uuid())
  derivationLayer DerivationLayer @map("derivation_layer")
  method          String
  sampleWindow    String?         @map("sample_window")
  evidence        Json? // the cold blob
  derivedAt       DateTime        @map("derived_at")
  createdAt       DateTime        @default(now()) @map("created_at")

  barSets MetricBarSet[]

  @@map("score_bar_provenance")
}

// Versioned band cuts for the 4 Market sub-components.
// FINAL RULING 7: Market sub-component band cuts ARE per-PG (§10.4) → keyed by
// peerGroupId. (Overrides the design draft, which keyed only by subComponent.)
// Cuts stored as explicit ordered columns (p15/p35/p65/p85) for the
// "crossed a market band" universe scan.
// RETIRED on the universal-Market build (2026-06-19). The Phase-4 Market used per-PG
// percentile band sets (score_market_band_sets); the universal Market scores via an
// in-code CUTS table (CN-1: one universal mechanism, no per-PG band rows). The model
// + table are dropped (mirrors the Phase-4 Market code deletion). MarketSubScore no
// longer FKs here.

// FINAL RULING 7: the Ownership FLOW band-cut / point values are ONE UNIVERSAL
// set for every stock — explicitly NOT keyed by peerGroup. Heterogeneous across
// the band types (Category C net-insider bands, Category D net-block bands,
// trend-bonus values), so the ordered cut→point pairs are stored as JSON.
// OwnershipFlowCategory references the version it used (reproducibility).
model OwnershipFlowBandSet {
  id            String                @id @default(uuid())
  bandType      OwnershipFlowBandType @map("band_type")
  version       Int
  cuts          Json // ordered { cut, points } pairs — universal, not per-PG
  inForceFrom   DateTime              @map("in_force_from") @db.Date
  specVersionId String                @map("spec_version_id")
  createdAt     DateTime              @default(now()) @map("created_at")

  specVersion    ScoringSpecVersion      @relation(fields: [specVersionId], references: [id])
  flowCategories OwnershipFlowCategory[]

  @@unique([bandType, version])
  @@index([bandType, inForceFrom(sort: Desc)])
  @@map("score_ownership_flow_band_sets")
}

enum OwnershipFlowBandType {
  c_net_insider
  d_net_block
  trend_bonus
}

// L2 peer μ/σ per (peerGroup, metric, run). PG-grain, shared by all PG members.
// FINAL RULING 8: keyed STRICTLY per-PG with NO inheritance pointer — PG6
// always computes its own Lens-2 / Lens-3. (The draft's inheritsFromPeerGroupId
// was removed from here and lives only on MetricBarSet.)
model PeerStatsSnapshot {
  id              String          @id @default(uuid())
  peerGroupId     String          @map("peer_group_id")
  barPath         String          @map("bar_path")
  metricKey       String          @map("metric_key")
  runId           String          @map("run_id")
  asOfDate        DateTime        @map("as_of_date") @db.Date
  mean            Decimal         @db.Decimal(18, 4)
  stdDev          Decimal         @map("std_dev") @db.Decimal(18, 4)
  sampleN         Int             @map("sample_n")
  anchorLiftFired Boolean         @default(false) @map("anchor_lift_fired") // §5.3.1 / §5.4.1
  anchorLiftRule  AnchorLiftRule? @map("anchor_lift_rule")
  createdAt       DateTime        @default(now()) @map("created_at")

  run          ScoringRun    @relation(fields: [runId], references: [id])
  metricScores MetricScore[]

  // Identity is (PG, metric, run, AS-OF). asOfDate is REQUIRED in the key because the
  // historical backfill scores many PERIODS under ONE runId — peer μ/σ is per-period,
  // so (PG, metric, runId) alone would collide across quarters. The live/rescore path
  // uses one run per period, so asOfDate just makes the per-pass row explicit there.
  @@unique([peerGroupId, metricKey, runId, asOfDate], name: "peer_stats_identity")
  @@index([runId, metricKey])
  @@index([peerGroupId, asOfDate]) // natural-key read lookup (assembler fallback when the MetricScore FK is null)
  @@map("score_peer_stats")
}

// Single source of truth for band → label → colour → numeric cut ranges.
// Each ScoreSnapshot pins the mapping version that produced its band, so a
// future re-band writes a NEW mapping and old snapshots keep their old mapping.
model BandMappingVersion {
  id            String   @id @default(uuid())
  version       String
  mapping       Json // band → { label, colour, range }
  effectiveFrom DateTime @map("effective_from") @db.Date
  createdAt     DateTime @default(now()) @map("created_at")

  snapshots ScoreSnapshot[]

  @@unique([version])
  @@map("score_band_mappings")
}

// ─────────────────────────────────────────────────────────────
// GROUP 2 — PER-STOCK SCORING STATE (satellite of the off-limits Stock)
// ─────────────────────────────────────────────────────────────

enum CoverageState {
  scored
  covered
  off_platform
}

// Coverage state, independent of PG assignment. Lives here because Stock is
// input-layer and off-limits.
// APPEND-ONLY (ruling 1): NOT 1:1 — a coverage change writes a NEW row;
// newest-by-createdAt wins on read. (The draft proposed @@unique([stockId])
// 1:1, but a single mutable row contradicts the no-update rule.)
model StockScoringState {
  id              String        @id @default(uuid())
  stockId         String        @map("stock_id")
  symbol          String // denormalised for join-free coverage scans
  coverageState   CoverageState @map("coverage_state")
  coverageReason  String?       @map("coverage_reason")
  lastScoredRunId String?       @map("last_scored_run_id") // plain ref (run id)
  createdAt       DateTime      @default(now()) @map("created_at")

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([stockId, createdAt(sort: Desc)]) // latest coverage per stock
  @@index([coverageState])
  @@map("score_stock_states")
}

// ─────────────────────────────────────────────────────────────
// GROUP 3 — THE SCORE SPINE (composite → pillar → leaf)
// ─────────────────────────────────────────────────────────────

enum SnapshotType {
  quarterly
  live
}

enum LabelBand {
  fragile
  below_par
  steady
  healthy
  pristine
}

enum WeightRedistributionReason {
  none
  market_unavailable
  missing_pillar
  guardrail_suppression
}

enum Pillar {
  foundation
  momentum
  market
  ownership
}

enum PillarState {
  scored
  unavailable_redistributed
}

// L1 landing band — fixed 5-tier naming (only the threshold VALUES version).
enum MetricBand {
  excellent
  good
  acceptable
  concerning
  distress
}

// Market sub-component landing band, named by the percentile cut it fell in.
// RETIRED on the universal-Market build (2026-06-19). The Phase-4 Market landed on a
// distributional percentile bucket (p0_p15…p85_p100); the universal Market lands on the
// Lens-1 quality band (MetricBand: excellent..distress), so MarketSubScore.band reuses
// MetricBand. This percentile enum is no longer referenced and is dropped.

enum LensFallback {
  none
  l2_to_l1
  l3_insufficient_history
}

// FINAL RULING 5 — the three not-scored states + genuine, distinguishable from
// (scoreState, effectiveWeight, includedInPeerStats):
//   scored         : effectiveWeight = nominal, includedInPeerStats = true
//   suppressed     : effectiveWeight = 0,       includedInPeerStats = FALSE (leaves peer μ/σ)
//   missing_renorm : effectiveWeight = 0,       includedInPeerStats = false
//   neutral_hold   : score = 60, effectiveWeight = FULL (kept, NOT renormalised),
//                    includedInPeerStats = TRUE (stays in peer μ/σ — the opposite of suppressed)
enum MetricScoreState {
  scored
  suppressed
  missing_renorm
  neutral_hold
}

// Threshold is 8 consecutive trailing quarters of shareholding data (§11.10-fix
// supersedes the "3 quarters" line in §11.5).
enum OwnershipBaselineReason {
  insufficient_history_60 // < 8 consecutive trailing quarters present — data-absent neutral baseline
  established_75 // ≥ 8 consecutive trailing quarters present — elevated baseline
}

enum FlowCategory {
  A_promoter
  B_institutional
  C_insider
  D_block
}

// FINAL RULING 6 — dormant ≠ zero. A dormant category contributes 0 WITH the
// state recorded, never a silent 0. Convention (set by the write path, since a
// per-category column default is not expressible): Categories C & D default to
// dormant_no_feed (PIT / bhavcopy not wired yet); A & B to scored.
enum FlowCategoryState {
  scored
  dormant_no_feed
  dormant_no_data
}

enum FlowTrendState {
  three_up
  three_down
  mixed
  neutral
}

// THE COMPOSITE ROW. References the four in-force pillar rows by FK (ruling 2);
// it does NOT own a fresh copy of the pillars. Pillar subtotals, applied
// weights, divergence, and label are denormalised here so the trajectory view
// (QP2) and "latest live per stock" (req 4) are a single index range scan —
// safe because the snapshot is immutable, so the copies can never drift.
//
// SUPERSEDE / NEWEST-WINS (ruling 3, reconciled with append-only ruling 1):
// a restated quarter writes a NEW `version` and points `supersedesId` at the
// prior row. Nothing is overwritten; reads take MAX(version) per
// (stock, type, periodKey). No mutable isCurrent flag, because flipping it would
// be an in-place update — forbidden by ruling 1.
model ScoreSnapshot {
  id            String       @id @default(uuid())
  stockId       String       @map("stock_id")
  symbol        String // denormalised
  snapshotType  SnapshotType @map("snapshot_type")
  periodKey     String       @map("period_key") // quarterly: "FY26Q1"; live: "LIVE:<runId>"
  asOfDate      DateTime     @map("as_of_date") @db.Date
  runId         String       @map("run_id")
  specVersionId String       @map("spec_version_id")

  // Supersede / version chain (append-only; newest version wins on read)
  version      Int     @default(1)
  supersedesId String? @map("supersedes_id")

  // Membership captured at stamp time — frozen so a PG reshuffle never rewrites history
  peerGroupId  String @map("peer_group_id")
  barPath      String @map("bar_path")
  industryPath String @map("industry_path") // "non_financial" | "banking"

  // Composite + label (ruling 13: band is a cache pinned to its mapping version)
  composite            Decimal   @db.Decimal(8, 4)
  labelBand            LabelBand @map("label_band")
  bandMappingVersionId String    @map("band_mapping_version_id")

  // The four in-force pillar references (ruling 2 — approach (a))
  foundationPillarId String @map("foundation_pillar_id")
  momentumPillarId   String @map("momentum_pillar_id")
  marketPillarId     String @map("market_pillar_id")
  ownershipPillarId  String @map("ownership_pillar_id")

  // Denormalised pillar subtotals (immutable copies — QP2 trajectory scan)
  foundationSubtotal Decimal @map("foundation_subtotal") @db.Decimal(8, 4)
  momentumSubtotal   Decimal @map("momentum_subtotal") @db.Decimal(8, 4)
  marketSubtotal     Decimal @map("market_subtotal") @db.Decimal(8, 4)
  ownershipSubtotal  Decimal @map("ownership_subtotal") @db.Decimal(8, 4)

  // Applied weight set inline (§14.4 redistribution) — per-snapshot, NOT versioned
  wFoundation                Decimal                    @map("w_foundation") @db.Decimal(8, 4)
  wMomentum                  Decimal                    @map("w_momentum") @db.Decimal(8, 4)
  wMarket                    Decimal                    @map("w_market") @db.Decimal(8, 4)
  wOwnership                 Decimal                    @map("w_ownership") @db.Decimal(8, 4)
  weightRedistributionReason WeightRedistributionReason @default(none) @map("weight_redistribution_reason")

  divergence Decimal @db.Decimal(8, 4) // per-snapshot scalar; "widening" computed on read

  // Pond mask (File 1 §5 / File 2 §3.3) — the PG-level "is the pond hot" signal, denormalised
  // onto EVERY member's snapshot (a PGState property inherited by every member). Pure-price
  // ~21d trailing move of the pond. Display-only modifier (annotates B/C1/D); never changes
  // scoring. Nullable: null ⇒ not established (no member quorum) ⇒ read layer treats as no-mask.
  maskHeat          String?  @map("mask_heat") // "hot" | "warm" | "calm" | null
  pgTrailingMovePct Decimal? @map("pg_trailing_move_pct") @db.Decimal(8, 4) // signed pond median ~21d return %

  // Skip-identical fingerprint (ruling 3) — engine-side no-op check for composites
  inputsFingerprint String @map("inputs_fingerprint")

  createdAt DateTime @default(now()) @map("created_at")

  stock              Stock              @relation(fields: [stockId], references: [id], onDelete: Cascade)
  run                ScoringRun         @relation(fields: [runId], references: [id])
  specVersion        ScoringSpecVersion @relation(fields: [specVersionId], references: [id])
  bandMappingVersion BandMappingVersion @relation(fields: [bandMappingVersionId], references: [id])

  foundationPillar PillarScore @relation("FoundationPillar", fields: [foundationPillarId], references: [id], onDelete: Cascade)
  momentumPillar   PillarScore @relation("MomentumPillar", fields: [momentumPillarId], references: [id], onDelete: Cascade)
  marketPillar     PillarScore @relation("MarketPillar", fields: [marketPillarId], references: [id], onDelete: Cascade)
  ownershipPillar  PillarScore @relation("OwnershipPillar", fields: [ownershipPillarId], references: [id], onDelete: Cascade)

  supersedes   ScoreSnapshot? @relation("SnapshotSupersede", fields: [supersedesId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  supersededBy ScoreSnapshot? @relation("SnapshotSupersede")

  patterns        ScorePattern[]
  redFlags        RedFlag[]
  guardrailEvents GuardrailEvent[]

  @@unique([stockId, snapshotType, periodKey, version]) // immutability + version history retained
  @@unique([supersedesId]) // a row supersedes at most one prior version (clean chain)
  @@index([stockId, snapshotType, asOfDate(sort: Desc)]) // req 4: latest live per stock; QP1/QP2
  @@index([peerGroupId, periodKey]) // QP3: PG panel for one snapshot
  @@index([periodKey, composite]) // QP5: universe band scans
  @@index([asOfDate, labelBand]) // QP5
  @@map("score_snapshots")
}

// COMPOSITE → PILLAR level. STOCK-GRAIN, append-only, EVENT-DRIVEN versioned
// (ruling 2): a new row only when this pillar's inputs change. Reused across
// every snapshot whose inputs are unchanged. Composite-relative weighting is
// NOT stored here (it differs per snapshot and lives inline on ScoreSnapshot);
// this row carries only the pillar's intrinsic subtotal/state and owns its
// leaves.
//
// THE structural guard for ruling 2: @@unique([stockId, pillar, inputsFingerprint]).
// inputsFingerprint hashes the pillar's full input set INCLUDING sourcePeriod,
// so identical inputs (e.g. a price-only day for Foundation) cannot insert a
// second row — Foundation is physically incapable of a duplicate daily row —
// while a genuine input change yields a new fingerprint → a new version.
model PillarScore {
  id                String      @id @default(uuid())
  stockId           String      @map("stock_id")
  symbol            String // denormalised
  pillar            Pillar
  subtotal          Decimal     @db.Decimal(8, 4)
  pillarState       PillarState @default(scored) @map("pillar_state")
  sourcePeriod      String      @map("source_period") // "FY25" / "FY26Q1" / price date
  asOfDate          DateTime    @map("as_of_date") @db.Date
  runId             String      @map("run_id")
  specVersionId     String      @map("spec_version_id")
  inputsFingerprint String      @map("inputs_fingerprint")
  createdAt         DateTime    @default(now()) @map("created_at")

  stock       Stock              @relation(fields: [stockId], references: [id], onDelete: Cascade)
  run         ScoringRun         @relation(fields: [runId], references: [id])
  specVersion ScoringSpecVersion @relation(fields: [specVersionId], references: [id])

  // Leaves hang off the pillar (reused with it), NOT off the snapshot
  metricScores    MetricScore[]
  marketSubScores MarketSubScore[]
  ownershipScore  OwnershipScore?

  // The four snapshot reference relations (a snapshot points here)
  foundationSnapshots ScoreSnapshot[] @relation("FoundationPillar")
  momentumSnapshots   ScoreSnapshot[] @relation("MomentumPillar")
  marketSnapshots     ScoreSnapshot[] @relation("MarketPillar")
  ownershipSnapshots  ScoreSnapshot[] @relation("OwnershipPillar")

  @@unique([stockId, pillar, inputsFingerprint], name: "score_pillar_input_identity") // ruling 2 guard
  @@index([stockId, pillar, asOfDate(sort: Desc)]) // resolve the in-force pillar at a date
  @@map("score_pillars")
}

// 3-LENS LEAF (Foundation + Momentum). ONE row per (pillar version, metric),
// L1/L2/L3 as columns (ruling 9). Physically owned by the pillar; logically one
// row per (snapshot, metric) via the snapshot's pillar FK — reused, never
// rewritten, on an unchanged day.
//
// Anchor reconstructability (ruling 9): l2/l3 store BOTH the anchor-fired flag
// AND the anchor value actually applied (60 or lifted 75), so "why a 75 not a
// 60" is answerable from the row without re-deriving the 75% count.
model MetricScore {
  id            String @id @default(uuid())
  pillarScoreId String @map("pillar_score_id")
  pillar        Pillar // denormalised for join-free filtering
  metricKey     String @map("metric_key")

  rawValue    Decimal  @map("raw_value") @db.Decimal(18, 4)
  l1Score     Decimal? @map("l1_score") @db.Decimal(8, 4)
  l2Score     Decimal? @map("l2_score") @db.Decimal(8, 4)
  l3Score     Decimal? @map("l3_score") @db.Decimal(8, 4)
  metricScore Decimal  @map("metric_score") @db.Decimal(8, 4) // = (L1+L2+L3)/3, stored

  // L1 landing + the exact bar VERSION used
  l1Band         MetricBand? @map("l1_band")
  metricBarSetId String?     @map("metric_bar_set_id")

  // L2 link + anchor reconstructability
  l2AnchorFired       Boolean  @default(false) @map("l2_anchor_fired")
  l2AnchorApplied     Decimal? @map("l2_anchor_applied") @db.Decimal(8, 4) // 60 or lifted 75
  peerStatsSnapshotId String?  @map("peer_stats_snapshot_id")

  // L3 own-history inline (STOCK-grain — never shared) + anchor reconstructability
  l3Mean          Decimal? @map("l3_mean") @db.Decimal(18, 4)
  l3StdDev        Decimal? @map("l3_std_dev") @db.Decimal(18, 4)
  l3WindowN       Int?     @map("l3_window_n")
  l3AnchorFired   Boolean  @default(false) @map("l3_anchor_fired")
  l3AnchorApplied Decimal? @map("l3_anchor_applied") @db.Decimal(8, 4)

  // Lens availability / fallback fact
  l1Available         Boolean      @default(true) @map("l1_available")
  l2Available         Boolean      @default(true) @map("l2_available")
  l3Available         Boolean      @default(true) @map("l3_available")
  lensFallbackApplied LensFallback @default(none) @map("lens_fallback_applied")

  // Intra-pillar weighting + not-scored state (ruling 5)
  nominalWeight       Decimal          @map("nominal_weight") @db.Decimal(8, 4)
  effectiveWeight     Decimal          @map("effective_weight") @db.Decimal(8, 4)
  contribution        Decimal          @db.Decimal(8, 4)
  scoreState          MetricScoreState @map("score_state")
  includedInPeerStats Boolean          @map("included_in_peer_stats")

  createdAt DateTime @default(now()) @map("created_at")

  pillarScore  PillarScore        @relation(fields: [pillarScoreId], references: [id], onDelete: Cascade)
  metricBarSet MetricBarSet?      @relation(fields: [metricBarSetId], references: [id])
  peerStats    PeerStatsSnapshot? @relation(fields: [peerStatsSnapshotId], references: [id])

  @@unique([pillarScoreId, metricKey]) // QP6: one row joins to bars + peer-stats
  @@index([pillarScoreId])
  @@index([metricKey, scoreState]) // universe metric scans
  @@map("score_metrics")
}

// The 7 universal Market sub-components, Lens-1-scored. Owned by the Market pillar.
// CN-6: EVERY sub-component is stored — a scoreable one carries raw/score/band; an
// EXCLUDED one (min-history / no peer pool) carries available=false + reason with null
// raw/score/band. A quarantined/excluded Market pillar still writes all 7 rows (the
// honest decomposition), never a silent drop.
model MarketSubScore {
  id            String             @id @default(uuid())
  pillarScoreId String             @map("pillar_score_id")
  subComponent  MarketSubComponent @map("sub_component") // A1/A2/B1/B2/B3/C1/D1
  category      MarketCategory // A/B/C/D — the §5 category this sub rolls into

  available Boolean // false = excluded (min-history / no peer pool)
  reason    String? // exclusion reason when !available (CN-6)

  // Universal Market scores via Lens-1 mechanics (CN-1: one in-code CUTS table, no
  // per-PG band set). raw/score/band are null when the sub-component is excluded.
  rawValue  Decimal?    @map("raw_value") @db.Decimal(18, 4)
  score     Decimal?    @db.Decimal(8, 4) // 0–100 Lens-1 score
  band      MetricBand? // excellent..distress (Lens-1 quality band)
  saturated Boolean     @default(false) // ±10/band-width saturation fired
  capped    Boolean     @default(false) // B2 categorical hit the 90 cap

  createdAt DateTime @default(now()) @map("created_at")

  pillarScore PillarScore @relation(fields: [pillarScoreId], references: [id], onDelete: Cascade)

  @@unique([pillarScoreId, subComponent])
  @@index([pillarScoreId])
  @@map("score_market_subs")
}

// Ownership primary sublayer + flow rollup. 1:1 with the Ownership pillar.
// Every term is a stored fact → primarySubtotal and finalOwnership are both
// re-derivable; a 0 penalty is a real stored 0, not an absence.
model OwnershipScore {
  id                    String                  @id @default(uuid())
  pillarScoreId         String                  @map("pillar_score_id")
  baseline              Decimal                 @db.Decimal(8, 4) // 60 or 75
  baselineReason        OwnershipBaselineReason @map("baseline_reason")
  pledgingAdjustment    Decimal                 @map("pledging_adjustment") @db.Decimal(8, 4)
  penaltyR2             Decimal                 @map("penalty_r2") @db.Decimal(8, 4)
  penaltyR6             Decimal                 @map("penalty_r6") @db.Decimal(8, 4)
  penaltyProlongedFii   Decimal                 @map("penalty_prolonged_fii") @db.Decimal(8, 4)
  primarySubtotal       Decimal                 @map("primary_subtotal") @db.Decimal(8, 4)
  flowAdjustmentRaw     Decimal                 @map("flow_adjustment_raw") @db.Decimal(8, 4)
  flowAdjustmentClamped Decimal                 @map("flow_adjustment_clamped") @db.Decimal(8, 4) // clamp(raw, -12, +12)
  finalOwnership        Decimal                 @map("final_ownership") @db.Decimal(8, 4) // clamp(primary + flowClamped, 40, 100)

  // R1 pledge red-flag FIRING RECORD (the breach is a red flag, NOT a pillar nudge).
  // The score_red_flags ROW stays deferred (it needs a ScoreSnapshot, snapshot_id
  // NOT NULL → out-of-scope pillars), but R1's firing is recorded HERE so that row
  // is later RECONSTRUCTABLE from stored facts, never recomputed. triggeringValues
  // captures { pledgeRatioQ, pledgeRatioQ1, qoqRisePp, breaches[] }.
  r1Fired            Boolean @default(false) @map("r1_fired")
  r1TriggeringValues Json?   @map("r1_triggering_values")

  createdAt DateTime @default(now()) @map("created_at")

  pillarScore    PillarScore             @relation(fields: [pillarScoreId], references: [id], onDelete: Cascade)
  flowCategories OwnershipFlowCategory[]

  @@unique([pillarScoreId])
  @@map("score_ownership")
}

// The 4 flow categories. RULING 6: each carries categoryState — a dormant
// category contributes a real 0 WITH the reason recorded (dormant_no_feed vs
// dormant_no_data), distinct from a scored neutral 0. References the universal
// flow band-set version it used (ruling 7) for reproducibility.
model OwnershipFlowCategory {
  id               String            @id @default(uuid())
  ownershipScoreId String            @map("ownership_score_id")
  category         FlowCategory
  rawSubScore      Decimal           @map("raw_sub_score") @db.Decimal(8, 4)
  capApplied       Decimal           @map("cap_applied") @db.Decimal(8, 4)
  cappedSubScore   Decimal           @map("capped_sub_score") @db.Decimal(8, 4) // summed into flowAdjustmentRaw
  categoryState    FlowCategoryState @map("category_state") // ruling 6
  bandLanded       String?           @map("band_landed") // label/key from the in-force universal band-set
  netFlowValue     Decimal?          @map("net_flow_value") @db.Decimal(18, 4) // signed ₹Cr or %
  trendState       FlowTrendState?   @map("trend_state")
  flowBandSetId    String?           @map("flow_band_set_id")
  createdAt        DateTime          @default(now()) @map("created_at")

  ownershipScore OwnershipScore        @relation(fields: [ownershipScoreId], references: [id], onDelete: Cascade)
  flowBandSet    OwnershipFlowBandSet? @relation(fields: [flowBandSetId], references: [id])

  @@unique([ownershipScoreId, category])
  @@index([ownershipScoreId])
  @@map("score_ownership_flows")
}

// ─────────────────────────────────────────────────────────────
// GROUP 4 — SIGNALS, GUARDRAILS, CACHES
// ─────────────────────────────────────────────────────────────

enum GuardrailOutcome {
  O1
  O2
  O3
  O4
  O5
  O6
}

enum GuardrailTier {
  auto
  review
}

enum GuardrailRuling {
  upheld
  overridden
  deferred
}

// First-class detected patterns (divergence, trajectory structure).
model ScorePattern {
  id           String   @id @default(uuid())
  snapshotId   String   @map("snapshot_id")
  symbol       String // denormalised
  asOfDate     DateTime @map("as_of_date") @db.Date // denormalised
  patternKey   String   @map("pattern_key")
  direction    String?
  severity     String?
  // Three mandatory display states (File 1 §5E): "active" | "pending_data_integration"
  // | "dampened". Free String (matches the codebase convention for soft-classification
  // fields, e.g. severity/direction) — defaults to "active" so existing readers are safe.
  displayState String   @default("active") @map("display_state")
  // EFFECTIVE score impact applied this snapshot (File 1 §5E: Green +5 / Amber −3 / Red
  // −8 / P13 ±5). For a dampened pattern this is the HALVED value (so −3 → −1.5 — Decimal,
  // not Int, to survive halving). Nullable: a pending_data_integration chip carries no
  // numeric impact. The base catalog magnitude is reconstructable from patternKey.
  magnitude    Decimal? @db.Decimal(6, 2)
  evidence     Json? // the underlying values (the UI reads this to build the verdict sentence)
  metricRefs   Json?    @map("metric_refs") // array of metricKeys
  createdAt    DateTime @default(now()) @map("created_at")

  snapshot ScoreSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([asOfDate, patternKey]) // QP5: "every widening divergence"
  @@index([snapshotId]) // QP1
  @@map("score_patterns")
}

// First-class red flags, universe-queryable.
model RedFlag {
  id               String        @id @default(uuid())
  snapshotId       String        @map("snapshot_id")
  symbol           String // denormalised
  asOfDate         DateTime      @map("as_of_date") @db.Date // denormalised
  flagKey          String        @map("flag_key")
  severity         String?
  tier             GuardrailTier
  triggeringValues Json?         @map("triggering_values")
  guardrailEventId String?       @map("guardrail_event_id") // set when the flag came from a guardrail
  createdAt        DateTime      @default(now()) @map("created_at")

  snapshot       ScoreSnapshot   @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  guardrailEvent GuardrailEvent? @relation(fields: [guardrailEventId], references: [id], onDelete: Cascade)

  @@index([asOfDate, flagKey]) // QP5: "every red flag this quarter"
  @@index([snapshotId]) // QP1
  @@index([tier])
  @@map("score_red_flags")
}

// Every guardrail signature that fired: triggering values + outcome (O1–O6) +
// tier. To find which metrics this event suppressed, query score_suppressions
// WHERE source_guardrail_event_id = <this id> — that table is the sole authority.
model GuardrailEvent {
  id               String           @id @default(uuid())
  stockId          String           @map("stock_id")
  snapshotId       String           @map("snapshot_id")
  signatureKey     String           @map("signature_key")
  triggeringValues Json?            @map("triggering_values")
  outcome          GuardrailOutcome
  tier             GuardrailTier
  createdAt        DateTime         @default(now()) @map("created_at")

  stock    Stock         @relation(fields: [stockId], references: [id], onDelete: Cascade)
  snapshot ScoreSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  reviews               GuardrailReview[]
  suppressionDirectives SuppressionDirective[]
  redFlags              RedFlag[]

  @@unique([snapshotId, signatureKey]) // a signature fires at most once per snapshot
  @@index([snapshotId])
  @@index([signatureKey, outcome]) // universe guardrail scans
  @@map("score_guardrail_events")
}

// THE SINGLE SEAM (rulings 8a, 12 / req 14). The one canonical, PG-AGNOSTIC
// representation of "this metric is suppressed for this stock at this snapshot."
// Written by Layer 1 (guardrail eval); read by BOTH the Layer-2 scoring core
// AND the peer-stats builder from the SAME row. That single coupling point is
// what forces a suppressed metric to drop from own-score AND from every peer's
// μ/σ together (CN-1 anti-drift):
//   • the scoring core reads excludeFromOwnScore → MetricScore.scoreState=suppressed
//   • the PEER-STATS BUILDER, when computing PeerStatsSnapshot.mean/stdDev for a
//     (PG, metric), excludes every member whose directive has
//     excludeFromPeerMean=true for that (snapshotKey, metric).
// stockId is a plain captured key (PG-agnostic lookup); provenance + teardown
// run through sourceGuardrailEventId.
model SuppressionDirective {
  id                     String           @id @default(uuid())
  stockId                String           @map("stock_id")
  snapshotKey            String           @map("snapshot_key") // runId (live) | periodKey (quarterly)
  metricKey              String           @map("metric_key")
  sourceGuardrailEventId String           @map("source_guardrail_event_id")
  outcome                GuardrailOutcome
  excludeFromOwnScore    Boolean          @default(true) @map("exclude_from_own_score")
  excludeFromPeerMean    Boolean          @default(true) @map("exclude_from_peer_mean")
  createdAt              DateTime         @default(now()) @map("created_at")

  sourceGuardrailEvent GuardrailEvent @relation(fields: [sourceGuardrailEventId], references: [id], onDelete: Cascade)

  @@unique([stockId, snapshotKey, metricKey])
  @@index([snapshotKey, metricKey]) // the peer-stats builder's "who to exclude from this metric's μ/σ"
  @@map("score_suppressions")
}

// Append-only operator ruling for review-tier flags. A changed ruling is a NEW
// row; latest ruledAt wins on read (consistent with the no-update rule).
model GuardrailReview {
  id               String          @id @default(uuid())
  guardrailEventId String          @map("guardrail_event_id")
  operatorId       String          @map("operator_id")
  ruling           GuardrailRuling
  reason           String?
  ruledAt          DateTime        @map("ruled_at")
  createdAt        DateTime        @default(now()) @map("created_at")

  guardrailEvent GuardrailEvent @relation(fields: [guardrailEventId], references: [id], onDelete: Cascade)

  @@index([guardrailEventId, ruledAt(sort: Desc)]) // latest ruling on read
  @@map("score_guardrail_reviews")
}

// Sector Health = arithmetic MEAN of member composites (ruling 15). A
// REGENERABLE cache stamped with the run that produced it — NOT a source of
// truth. Everything else cross-sectional (median, dispersion, ranks) is
// read-time. sectorId is a plain captured key (matches PeerGroupComputationLog).
model SectorHealthCache {
  id            String   @id @default(uuid())
  sectorId      String   @map("sector_id")
  runId         String   @map("run_id")
  asOfDate      DateTime @map("as_of_date") @db.Date
  meanComposite Decimal  @map("mean_composite") @db.Decimal(8, 4)
  memberCount   Int      @map("member_count")
  specVersionId String   @map("spec_version_id")
  createdAt     DateTime @default(now()) @map("created_at")

  run         ScoringRun         @relation(fields: [runId], references: [id])
  specVersion ScoringSpecVersion @relation(fields: [specVersionId], references: [id])

  @@unique([sectorId, runId])
  @@index([asOfDate])
  @@map("score_sector_health")
}

// ─────────────────────────────────────────────────────────────
// BANK SUPPLEMENTARY — manually-entered banking figures that are NOT in the
// Reg-33 XBRL (CASA ratio; pre-FY23 Tier-1 capital). These are disclosed only
// in bank investor presentations / press releases, so they are hand-entered
// WITH a source citation. The "verified figure or explicit MISSING, never a
// guess" discipline: a value with no source is rejected at ingest (sourceCitation
// is non-null by design).
//
// APPEND-ONLY + SUPERSEDE (same mechanic as score_snapshots, rulings 1/3): a
// corrected re-entry writes a NEW `version` and points `supersedesId` at the
// prior row. Nothing is updated in place (no updatedAt). Reads take MAX(version)
// per cell — newest wins.
//
// General & metric-keyed so multiple supplementary metrics coexist (CASA now,
// Tier-1 history now, others later) WITHOUT a new migration.
// ─────────────────────────────────────────────────────────────
enum BankSupplementaryMetric {
  casa_pct // CASA ratio — unit = PERCENT (e.g. 43.82 means 43.82%)
  tier1_pct // Tier-1 capital ratio — unit = PERCENT (e.g. 14.50 means 14.50%)
}

model BankSupplementary {
  id      String @id @default(uuid())
  stockId String @map("stock_id")
  symbol  String // denormalised (repo convention) — bank ticker, e.g. "HDFCBANK"

  metric BankSupplementaryMetric

  // Period key — matches how BankingFundamental keys periods (fiscalYear) plus a
  // nullable quarter. quarter = null means an ANNUAL figure.
  fiscalYear String  @map("fiscal_year") // "FY24"
  quarter    String? // "Q1".."Q4"; null = annual figure

  // The figure as a PERCENT, NOT a fraction: CASA 43.82 = 43.82%, Tier-1
  // 14.50 = 14.50%. (Banking ratio unit discipline — never store a fraction.)
  // NULL when status = "missing" (explicit gap — engine reads as neutral-60).
  value Decimal? @db.Decimal(8, 4)

  // Source traceability. NULL only when status = "missing" (no disclosure exists).
  // For status = "found", ingest enforces non-null (found⟹value+citation invariant).
  sourceCitation String?   @map("source_citation")
  sourceDate     DateTime? @map("source_date") @db.Date // null for missing rows

  // Data-quality flag: A = primary disclosure, B = derived/secondary, C = estimated.
  // NULL for missing rows.
  confidence String? // "A" | "B" | "C" | null

  // "found" | "missing". Missing rows are explicit gaps (engine §5.8 neutral-60 path).
  status String @default("found") // NOT NULL

  // Free-form annotation per row (e.g. why a period is missing).
  notes String?

  // Append-only supersede chain (newest version wins on read)
  version      Int     @default(1)
  supersedesId String? @map("supersedes_id")

  enteredBy String   @map("entered_by") // audit — "user:aman"
  createdAt DateTime @default(now()) @map("created_at")

  stock        Stock              @relation(fields: [stockId], references: [id], onDelete: Cascade)
  supersedes   BankSupplementary? @relation("BankSupplementarySupersede", fields: [supersedesId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  supersededBy BankSupplementary? @relation("BankSupplementarySupersede")

  // A corrected re-entry (new version) coexists with the prior; the same version
  // can't duplicate a cell. CAVEAT: Postgres treats NULL as DISTINCT in unique
  // indexes, so for ANNUAL rows (quarter = null) this does NOT enforce
  // uniqueness — the ingest route's read-before-write supersede check inside a
  // transaction is the authoritative guard for those rows. See FLAGS / format doc.
  @@unique([stockId, metric, fiscalYear, quarter, version])
  @@unique([supersedesId]) // a row supersedes at most one prior version (clean chain)
  @@index([stockId, metric, fiscalYear, quarter, version(sort: Desc)]) // "latest version for this cell" read path
  @@map("bank_supplementary")
}

// ─────────────────────────────────────────────
// STOCK OVERVIEW
// Hand-authored editorial content per stock.
// Source: stock_overview_static.json (v1.1+).
// Separate table — editorial lifecycle is
// independent of operational data on stocks.
// Loader: src/scripts/seed-stock-overview.ts
// ─────────────────────────────────────────────
model StockOverview {
  id           String   @id @default(uuid())
  stockId      String   @unique @map("stock_id")
  industry     String
  listedSince  Int?     @map("listed_since")
  coreBusiness String   @map("core_business") @db.Text
  revenueModel String   @map("revenue_model") @db.Text
  businessTags String[] @default([]) @map("business_tags")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@map("stock_overviews")
}

// ─────────────────────────────────────────────────────────────
// INGESTION ERROR  (shared, cron-agnostic detection framework)
//
// Per-VIOLATION detail for silent ingest failures (Class-B:
// 200-OK-with-bad-data — empty sets, renamed fields, wrong units —
// not loud 404s). Five guard families POPULATE this table by calling
// reportIngestionError() when a detection guard trips:
//   shape | count | null_rate | range | continuity
//
// COMPLEMENTS — does NOT replace — the per-RUN fetch logs
// (PriceFetchLog / ShareholdingFetchLog / …). Those stay one row per
// run (status/counts/duration). This is one row per violation
// (why / which field / seen-vs-expected). They link via `runRef`.
//
// SEVERITY drives behaviour + resolutionPath (the design rule):
//   critical = shape  → source_code, guard REJECTS data (no insert)
//   high     = count / skip-rate → source_code, data LANDS + flags
//   medium   = null_rate / range → MAY be admin_fill, data LANDS + flags
//   low      = continuity        → source_code/review, data LANDS + flags
//
// resolutionPath gates the resolution UI: admin_fill rows get a
// fill-button (a missing value an admin can source + cite); source_code
// rows do not (an admin can't type their way out of a broken endpoint).
// ─────────────────────────────────────────────────────────────
enum GuardType {
  shape // expected structure / columns present
  count // row count in expected band
  null_rate // per-field population rate (genuinely-nullable fields)
  range // value within bounds
  continuity // delta vs history
  // ── SCORING error class (source="scoring") — a SCORE that failed to compute
  //    properly even when the input data is fine. Distinct from the ingestion
  //    guards above (which catch bad data coming IN). Added so scoring errors
  //    share this table + its resolution UI / lifecycle / dedup.
  scoring_job_failed // a terminal-failed rescore BackgroundJob (Stage 1)
  scoring_degraded // a committed snapshot degraded unexpectedly (Stage 4)
  scoring_stale // a snapshot whose inputs moved since it was computed (Stage 3)
}

enum IngestionSeverity {
  critical // shape failure — reject + flag
  high // count anomaly / skip-rate spike
  medium // null-rate spike / range violation
  low // continuity flag (human eyeball)
}

enum ResolutionPath {
  source_code // developer / source-side fix (no fill-button)
  admin_fill // a specific value an admin can source + enter (fill-button)
  rescore // re-run the scoring job (scoring errors) — enqueue a rescore + poll the job.
  // fill-then-rescore reuses admin_fill (the existing fill bridge cascades a rescore).
}

enum IngestionErrorStatus {
  open
  resolved
  ignored
}

model IngestionError {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at") // first seen

  // ── Provenance: where the violation came from ──
  source String // "nse_bhavcopy"
  cron   String // "daily_eod_prices"

  guardType GuardType @map("guard_type")

  // ── Target: what the guard was checking ──
  targetTable  String  @map("target_table") // "DailyPrice"
  targetField  String? @map("target_field") // "close" — NULL for batch-level guards (shape/count/skip)
  targetEntity String? @map("target_entity") // symbol / priceDate — NULL when not field-level

  // ── Classification (severity drives behaviour + path) ──
  severity       IngestionSeverity
  resolutionPath ResolutionPath    @map("resolution_path")

  // ── Evidence ──
  expected String  @db.Text // "150–250 rows" / "close in [0.01,200000]"
  observed String  @db.Text // "12 rows" / "close=0.34"
  detail   String? @db.Text // human context
  runRef   String? @map("run_ref") // SOFT ref to the run-log identity ("<priceDate>:<provider>");
  // NOT a Prisma FK — each cron's run-log is a different table, and the
  // price log row is upserted at end-of-run (after guards fire).

  // ── Dedup bookkeeping (a daily recurring gap = 1 row, not 30) ──
  occurrences Int      @default(1) // bumped each time the same open violation re-trips
  lastSeenAt  DateTime @default(now()) @map("last_seen_at") // last detection (createdAt = first)

  // ── Resolution lifecycle ──
  status             IngestionErrorStatus @default(open)
  resolvedBy         String?              @map("resolved_by")
  resolvedAt         DateTime?            @map("resolved_at")
  resolutionCitation String?              @map("resolution_citation") @db.Text // CN-4: source the admin cited (admin_fill)
  resolutionNote     String?              @map("resolution_note") @db.Text

  // ── SCORING error class (source="scoring") — all nullable so ingestion rows are
  //    unaffected (they leave every column below NULL). Populated by reportScoringError.
  //    The dedup still rides the existing (cron, guardType, targetField, targetEntity,
  //    status) index — periodKey is folded into targetEntity for cascade rows, so these
  //    columns are structured/UI metadata, not part of the dedup key.
  pgId              String? @map("pg_id") // PG_RESCORE entity ("PG5"); null for symbol-keyed cascades
  periodKey         String? @map("period_key") // cascade edited period ("FY26Q2"); null for live pg_rescore
  failureType       String? @map("failure_type") // "job_failed" | "degraded" | "stale"
  degradationDetail Json?   @map("degradation_detail") // pillar/metric/presentRatio/lens — Stages 3/4
  recomputeAction   String? @map("recompute_action") // "rescore" | "fill_then_rescore" | "source_code"
  triggeringJobId   String? @map("triggering_job_id") // the failed BackgroundJob id (job_failed)
  snapshotId        String? @map("snapshot_id") // the affected ScoreSnapshot — Stages 3/4

  @@index([status, severity]) // triage queue
  @@index([cron, createdAt]) // per-cron history
  @@index([status, resolutionPath]) // fill-button vs source_code split
  @@index([cron, guardType, targetField, targetEntity, status]) // dedup lookup of the open instance
  @@map("ingestion_errors")
}

// ─────────────────────────────────────────────
// RAW FIELD EDIT — append-only audit trail for the admin raw-field fill bridge.
// One row per admin correction of a RAW fundamentals/shareholding field. The
// correction itself is applied IN-PLACE on the target row (those tables are
// upsert-in-place, not supersede-chained); this table is the citation history
// (CN-4: every raw edit carries a source attribution). Additive — apply via the
// drift-safe db-execute + migrate-resolve path (see [[invest-iq-migration-drift]]).
// ─────────────────────────────────────────────
model RawFieldEdit {
  id          String   @id @default(uuid())
  targetTable String   @map("target_table") // e.g. "Fundamental"
  targetRowId String   @map("target_row_id")
  field       String // the raw column corrected
  oldValue    String?  @map("old_value") // stringified prior value (audit)
  newValue    String?  @map("new_value") // stringified new value
  citation    String // CN-4: mandatory source attribution
  editedBy    String   @map("edited_by")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([targetTable, targetRowId])
  @@index([createdAt])
  @@map("raw_field_edits")
}

// ═════════════════════════════════════════════════════════════════
// USER LAYER  (Phase 1 — Supabase Auth)
// Five tables keyed to Supabase auth.users. auth.users is NOT modelled
// here (no multiSchema); the cross-schema FK on users.auth_user_id →
// auth.users.id lives in raw SQL in the migration, as does the signup
// trigger (handle_new_user) that seeds this row set on every new auth
// user. PK ids carry a DB-level gen_random_uuid()::text default (unlike
// the client-generated @default(uuid()) used elsewhere) because those
// rows are born inside the Postgres trigger, server-side.
// ═════════════════════════════════════════════════════════════════

enum UserRole {
  user
  admin
}

enum AiLevel {
  plain
  balanced
  technical
}

/// The spine. One row per Supabase auth user. Session middleware
/// resolves a request (JWT sub == auth.users.id) to this row; `role`
/// gates admin routes.
model User {
  id         String   @id @default(dbgenerated("gen_random_uuid()::text"))
  authUserId String   @unique @map("auth_user_id") @db.Uuid // FK → auth.users.id (declared in SQL)
  email      String
  role       UserRole @default(user)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  ledger         UserLedger?
  register       UserRegister?
  onboardingMeta UserOnboardingMeta?
  linkedAccounts LinkedAccount[]

  // ── Portfolio layer (user-authored ledger + materialized holdings) ──
  transactions Transaction[]
  holdings     Holding[]

  // ── Portfolio Health Score snapshots (compute-once, append-only) ──
  portfolioHealthSnapshots PortfolioHealthSnapshot[]

  // ── Watchlist (per-user pinned research surface; display-only, never scored) ──
  watchlist Watchlist[]

  // ── User-created alerts (rules) + the fired-events log (records only; no email) ──
  alerts      Alert[]
  alertEvents AlertEvent[]

  // ── Event reminders (date-triggered sibling of alerts) + their fired log ──
  eventReminders      EventReminder[]
  eventReminderEvents EventReminderEvent[]

  @@map("users")
}

/// Durable onboarding FACTS. One row per user; columns nullable so
/// onboarding fills them progressively (resumable).
model UserLedger {
  id          String  @id @default(dbgenerated("gen_random_uuid()::text"))
  userId      String  @unique @map("user_id")
  displayName String? @map("display_name")

  // categorical (text + CHECK in SQL — may evolve)
  financeDepth        String? @map("finance_depth") // casual | formal | professional
  termComfort         String? @map("term_comfort") // explain | follow | assume
  investingExperience String? @map("investing_experience") // starting | few_years | experienced
  investingStyle      String? @map("investing_style") // long_term | mix | active

  // adaptive flags (nullable booleans)
  selfTaught            Boolean? @map("self_taught")
  aspirationalTechnical Boolean? @map("aspirational_technical")
  concisePro            Boolean? @map("concise_pro")
  explainLeaning        Boolean? @map("explain_leaning")
  trustCredential       Boolean? @map("trust_credential")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_ledger")
}

/// Mutable SETTINGS (sovereign; may intentionally disagree with the ledger).
model UserRegister {
  id        String   @id @default(dbgenerated("gen_random_uuid()::text"))
  userId    String   @unique @map("user_id")
  aiLevel   AiLevel  @default(balanced) @map("ai_level") // never null — the doc's fallback
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_register")
}

/// Onboarding completion + LEGAL record. Disclaimer fields are the
/// liability shield — write-once in spirit (no overwrite path).
model UserOnboardingMeta {
  id                 String  @id @default(dbgenerated("gen_random_uuid()::text"))
  userId             String  @unique @map("user_id")
  onboardingComplete Boolean @default(false) @map("onboarding_complete")

  currentStep    String? @map("current_step") // step key where the user is
  completedSteps Json    @default("[]") @map("completed_steps") // array of completed step keys

  disclaimerAcceptedAt  DateTime? @map("disclaimer_accepted_at")
  disclaimerTextVersion String?   @map("disclaimer_text_version") // WHICH wording they accepted
  onboardingVersion     String?   @map("onboarding_version")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_onboarding_meta")
}

/// BROKER connections only (Zerodha/Upstox/Groww — future). NOT for
/// email/Google identity (Supabase's own provider-linking handles that).
model LinkedAccount {
  id                String   @id @default(dbgenerated("gen_random_uuid()::text"))
  userId            String   @map("user_id")
  provider          String // zerodha | upstox | groww | ...
  providerAccountId String?  @map("provider_account_id")
  metadata          Json?
  status            String   @default("pending")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@map("linked_accounts")
}

// ─────────────────────────────────────────────
// MARKET-CAP TIER SNAPSHOT — monthly FROZEN large/mid/small tier per stock, ranked
// on derived market cap (latest total_shares × latest daily close, via the existing
// computeMarketCap). Append-only: each monthly freeze appends a full set under a new
// as_of_date; prior sets are NEVER mutated (audit of tier movement — mirrors
// ScoreSnapshot's "captured at stamp time"). Latest as_of_date per stock = the live
// tier PHS reads. Live-ranking flickers near the 100/250 cuts (<1% gaps), so the tier
// is frozen monthly, not computed on read. DISPLAY/PHS only — a null-PG stock is still
// never scored. Additive; apply via the drift-safe db-execute + migrate-resolve path
// (see the RawFieldEdit comment / [[invest-iq-migration-drift]]).
// ─────────────────────────────────────────────
model MarketCapTierSnapshot {
  id            String        @id @default(uuid())
  stockId       String        @map("stock_id")
  tier          MarketCapTier
  rank          Int? // 1-based rank among rankable stocks; null ⇔ tier = unknown
  marketCap     Decimal?      @map("market_cap") @db.Decimal(20, 2) // ₹Cr ranked on; null ⇔ unknown
  // Why a stock is unknown (null when tier ≠ unknown). Distinct lifecycles: gated_split
  // self-heals at the next freeze; no_total_shares persists until a filing lands.
  unknownReason String?       @map("unknown_reason") // no_total_shares | no_price | gated_split
  asOfDate      DateTime      @map("as_of_date") @db.Date
  createdAt     DateTime      @default(now()) @map("created_at")

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, asOfDate]) // idempotency + natural key: one row per stock per freeze
  @@index([asOfDate]) // fetch a whole freeze / the latest freeze
  @@map("market_cap_tier_snapshot")
}

enum MarketCapTier {
  large
  mid
  small
  unknown
}

// ═══════════════════════════════════════════════════════════════
// PORTFOLIO LAYER — the foundation PHS reads. Three tables:
//   transactions  — SOURCE OF TRUTH (append-only, user-authored)
//   holdings      — MATERIALIZED, recomputed on every txn write (never hand-set)
//   holding_lots  — MATERIALIZED FIFO open-lot register (remainder after last replay)
// Broker-match: display cost = weighted-avg of OPEN lots; realized P&L = FIFO
// (oldest lot consumed first, IT-dept mandated). Full-replay-on-write so a
// back-dated insert or a late split recomputes everything. DISPLAY/PHS only —
// never touches scoring. Additive; apply via the drift-safe path.
// ═══════════════════════════════════════════════════════════════

enum TransactionType {
  buy
  sell
  split
  bonus
  dividend
}

/// SOURCE OF TRUTH — append-only, user-authored. Never mutated except a
/// correction (PATCH/DELETE), which triggers a full FIFO replay.
model Transaction {
  id        String          @id @default(uuid())
  userId    String          @map("user_id")
  stockId   String          @map("stock_id")
  type      TransactionType
  quantity  Decimal?        @db.Decimal(18, 4) // buy/sell shares; null for split/bonus/dividend
  price     Decimal?        @db.Decimal(18, 6) // buy/sell ₹/share; dividend ₹/share; null for split/bonus
  fees      Decimal?        @default(0) @db.Decimal(18, 6) // ₹ total charges (brokerage+STT+…); folds into cost basis (buy) / proceeds (sell); null = 0
  tradeDate DateTime        @map("trade_date") @db.Date
  ratio     String? // "a:b" for split/bonus (a additional per b held → factor (a+b)/b); null otherwise
  notes     String?
  createdAt DateTime        @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([userId, stockId, tradeDate, createdAt]) // the replay-order query
  @@map("transactions")
}

/// MATERIALIZED — one row per (user, stock) that has any transaction. Recomputed on
/// every write. qty may be 0 (fully exited): the row is KEPT so realized_pnl survives
/// (tax + broker Tax P&L); GET /holdings filters qty>0 for the current-holdings view.
model Holding {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  stockId        String   @map("stock_id")
  quantity       Decimal  @db.Decimal(18, 4) // current open qty (Σ open lots)
  avgCost        Decimal  @map("avg_cost") @db.Decimal(18, 6) // wtd-avg of OPEN lots = broker display cost
  investedValue  Decimal  @map("invested_value") @db.Decimal(20, 2) // Σ(lot.qty × lot.cost)
  realizedPnl    Decimal  @map("realized_pnl") @db.Decimal(20, 2) // cumulative FIFO-matched
  lastComputedAt DateTime @map("last_computed_at")

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock Stock        @relation(fields: [stockId], references: [id], onDelete: Cascade)
  lots  HoldingLot[]

  @@unique([userId, stockId])
  @@index([userId])
  @@map("holdings")
}

/// MATERIALIZED FIFO open-lot register — the frozen open remainder after the last
/// replay (consumed lots are not stored). Ordered by buy_date (FIFO). buy_date is
/// PRESERVED through splits/bonus so per-lot holding period (STCG/LTCG) is exact.
model HoldingLot {
  id           String   @id @default(uuid())
  holdingId    String   @map("holding_id")
  quantity     Decimal  @db.Decimal(18, 4)
  costPerShare Decimal  @map("cost_per_share") @db.Decimal(18, 6)
  buyDate      DateTime @map("buy_date") @db.Date
  sourceTxnId  String   @map("source_txn_id") // soft ref to the originating buy txn (lots are rebuilt each replay)

  holding Holding @relation(fields: [holdingId], references: [id], onDelete: Cascade)

  @@index([holdingId, buyDate])
  @@map("holding_lots")
}

// ═══════════════════════════════════════════════════════════════
// PORTFOLIO HEALTH SCORE SNAPSHOT (PHS Part A) — compute-once, append-only.
// One row per (portfolio=user, compute-event). The single source every surface
// reads (Overview, Health tab) — no surface re-runs the engine. PHS = holdings'
// quality (anchor) − penalty-only Structure/Signals, capped by coverage confidence.
// All constants stamped `portfolio-spec 1.1` (declared, not derived). Skip-write when
// the input fingerprint is unchanged from the user's latest snapshot (fingerprint UNCHANGED
// by 1.1 — the copy-only tiers are not in it). Additive; apply via the drift-safe path
// (see [[invest-iq-migration-drift]]).
// ═══════════════════════════════════════════════════════════════
model PortfolioHealthSnapshot {
  id     String @id @default(uuid())
  userId String @map("user_id") // the portfolio = the user's book

  // ── headline ──
  phs            Int? // published integer PHS; null when c=0 (construction-read only)
  phsRaw         Decimal? @map("phs_raw") @db.Decimal(8, 4) // pre-ceiling
  band           String? // Strong|Steady|Mixed|Fragile|Weak; null when no PHS
  provisional    Boolean  @default(false) // c < 0.40 (PROVISIONAL_BELOW)
  evaluable      Boolean  @default(true) // false ⇔ c=0 (no scored holdings)
  ceilingApplied Boolean  @map("ceiling_applied") // did the ceiling bind (ceiling < phs_raw)?
  ceilingValue   Int?     @map("ceiling_value") // ceiling in force; null when c≥0.80 (none)

  // ── pillars ──
  quality   Decimal? @db.Decimal(8, 4) // null when not evaluable
  structure Decimal  @db.Decimal(8, 4) // always computed (whole book)
  signals   Decimal  @db.Decimal(8, 4)

  // ── coverage + bucket value splits ──
  coverage                Decimal @db.Decimal(6, 4) // c
  totalValue              Decimal @map("total_value") @db.Decimal(20, 2)
  scoredValue             Decimal @map("scored_value") @db.Decimal(20, 2)
  recognizedUnscoredValue Decimal @map("recognized_unscored_value") @db.Decimal(20, 2)
  smallUnscoredValue      Decimal @map("small_unscored_value") @db.Decimal(20, 2)

  // ── full deduction ledgers (A.12) ──
  structureLedger Json  @map("structure_ledger") // every fired S-rule with its points
  signalsLedger   Json  @map("signals_ledger") // per-holding resolved Signals deduction + winning source
  firedFindings   Json? @map("fired_findings") // PF IDs (Part B) — always [] for Part A, column reserved

  // ── copy-only tiers (portfolio-spec 1.1, Change 2) — STORAGE + Part B copy SELECTOR.
  //    structureTier from holding count N; capitalTier from total value ₹. HARD LOCK:
  //    nothing in the score reads these — the PHS is byte-identical with or without them.
  //    Nullable: pre-1.1 rows keep NULL (migration-gated, no backfill). ──
  structureTier String? @map("structure_tier") // Starter | Building | Established
  capitalTier   String? @map("capital_tier") //   Modest | Moderate | Substantial

  // ── health-read enrichments (portfolio-spec 1.2, Change 4/5) — computed at snapshot time
  //    over the SCORED holdings. pillarProfile = position-weighted pillar means; lensProfile =
  //    findings-CHARACTER shares by lens nature (never attribution). Nullable: NULL when no
  //    scored holdings (both) or no lens patterns fired (lensProfile). Migration-gated. ──
  pillarProfile Json? @map("pillar_profile") // { foundation, momentum, market, ownership } | null
  lensProfile   Json? @map("lens_profile") //   { absolute, peer, trend } | null

  // ── provenance ──
  constantVersion String   @map("constant_version") // 'portfolio-spec 1.2'
  fingerprint     String // skip-write if == the user's latest snapshot's
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)]) // latest snapshot per user (the read path)
  @@index([fingerprint])
  @@map("portfolio_health_snapshot")
}

// ═══════════════════════════════════════════════════════════════
// WATCHLIST — per-user pinned research surface. One row per (user, stock) tracked.
// pinned_* is a BASELINE captured ONCE at add-time (the stock's health/band/price the
// moment it was pinned) — cheap now, unreconstructable later; the anchor for the future
// "changed since you added" signal. NEVER updated after insert. Everything else the
// surface shows (current health, findings, three-lens verdicts, live price) is
// READ-JOINED at query time from existing computed tables — never stored here. DISPLAY
// only; never scored. Additive; apply via the drift-safe db-execute + migrate-resolve
// path (see [[invest-iq-migration-drift]]).
// ═══════════════════════════════════════════════════════════════
model Watchlist {
  id      String @id @default(uuid())
  userId  String @map("user_id")
  stockId String @map("stock_id")

  addedAt DateTime @default(now()) @map("added_at")

  // ── two-tier favorites: star promotes a pin to a favorite (a MUTABLE flag, unlike the
  //    pinned_* baseline). Toggled via PATCH /me/watchlist/:stockId; drives the filter. ──
  favorite Boolean @default(false)

  // ── pin-time baseline (captured ONCE at insert; never updated) ──
  pinnedHealth Int?     @map("pinned_health") // composite (rounded) at pin-time; null ⇔ unscored then
  pinnedBand   String?  @map("pinned_band") // LabelBand string at pin-time; null ⇔ unscored then
  pinnedPrice  Decimal? @map("pinned_price") @db.Decimal(12, 2) // last close at pin-time; null ⇔ no price then

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([userId, stockId]) // idempotency + natural key: one pin per (user, stock)
  @@index([userId, addedAt(sort: Desc)]) // the list read path (a user's pins, newest first)
  @@map("watchlist")
}

// ═══════════════════════════════════════════════════════════════
// ALERTS — user-created rules on a stock (price / health_band / finding) + the
// fired-events log that email drains LATER. This build RECORDS fires only; it sends
// NOTHING. Same architecture as the other /me/* surfaces: auth-gated, IDOR-scoped,
// read-only over already-computed data (price / band / findings) — evaluate, never
// recompute. Firing is on CROSSING, not STATE (the `armed` re-arm flag is the anti-spam
// rule; see src/alerts/). Universe-gated (stock in the 505). A user may have many alerts
// per stock. Additive; applied via the drift-safe path ([[invest-iq-migration-drift]]).
// ═══════════════════════════════════════════════════════════════
model Alert {
  id      String @id @default(uuid())
  userId  String @map("user_id")
  stockId String @map("stock_id")

  type     AlertType
  operator AlertOperator // price/health_band → above|below; finding → fires (DB CHECK-enforced)

  // Polymorphic target — exactly ONE populated per type (DB CHECK-enforced):
  //   price       → thresholdPrice (compared to the latest EOD close)
  //   health_band → thresholdBand  (compared to the current band rank; enum ⇒ never invalid)
  //   finding     → findingKey     (a specific finding key, or null ⇒ "any new finding")
  thresholdPrice Decimal?   @map("threshold_price") @db.Decimal(14, 4)
  thresholdBand  LabelBand? @map("threshold_band")
  findingKey     String?    @map("finding_key")

  repeatMode AlertRepeatMode @default(one_shot) @map("repeat_mode")

  // Lifecycle. active: one_shot self-deactivates after firing; repeating stays active.
  // armed: the crossing/re-arm flag — fire only if armed && condition-true, then disarm;
  // re-arm (armed=true) only when the condition goes FALSE again. This is what stops a
  // persistently-true condition from firing every single day.
  active Boolean @default(true)
  armed  Boolean @default(true)

  lastTriggeredAt DateTime? @map("last_triggered_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock  Stock        @relation(fields: [stockId], references: [id], onDelete: Cascade)
  events AlertEvent[]

  @@index([userId, createdAt(sort: Desc)]) // the user's alerts list, newest first
  @@index([active]) // the daily eval pass scans ACTIVE alerts
  @@index([stockId])
  @@map("alerts")
}

// The FIRED log — one row per time an alert's condition crossed into true. This is what
// the (separate, later) email stage drains: `delivered` flips true when an email is sent.
// user_id + stock_id are denormalised so the IDOR-scoped log read needs no join. FK to
// alerts is CASCADE (delete an alert → its fired history goes with it, per spec).
model AlertEvent {
  id        String   @id @default(uuid())
  alertId   String   @map("alert_id")
  userId    String   @map("user_id")
  stockId   String   @map("stock_id")
  firedAt   DateTime @default(now()) @map("fired_at")
  snapshot  String // the value that triggered it, rendered (price / band / finding key)
  delivered Boolean  @default(false) // email flips this LATER; nothing sends in this build
  createdAt DateTime @default(now()) @map("created_at")

  alert Alert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([userId, firedAt(sort: Desc)]) // the user's fired-events log (in-app surface)
  @@index([alertId])
  @@index([delivered]) // the future email drain scans undelivered rows
  @@map("alert_events")
}

enum AlertType {
  price
  health_band
  finding
}

enum AlertOperator {
  above
  below
  fires
}

enum AlertRepeatMode {
  one_shot
  repeating
}

// ─────────────────────────────────────────────
// EVENT REMINDERS — the "simpler sibling" of alerts (Alert): a user asks to be reminded
// N days before a stock's next event of a given type. The trigger is a DATE, not a
// condition — that is the whole difference from an alert.
//
// SEMANTIC BINDING (not eventId): a reminder binds by (stockId, eventType), NOT to a
// specific corporate_events row. Every eval re-resolves "the stock's NEAREST upcoming
// event of that type", so a rescheduled date — which lands as a NEW corporate_events row
// (the upsert key is stockId+eventType+eventDate) — is FOLLOWED automatically. A reminder
// can never pin to a stale row.
//
// Simpler lifecycle than alerts: pause/resume (active) + delete only — there is no
// threshold to edit. Delivery REUSES the alerts email pipeline (the same Resend mailer +
// send-then-flip drain); this build only adds the reminder-shaped fired log + template.
model EventReminder {
  id      String @id @default(uuid())
  userId  String @map("user_id")
  stockId String @map("stock_id")

  // The corporate-event type this reminder watches (earnings | dividend | agm |
  // board_meeting | bonus | split | rights | buyback | record_date). Free TEXT to mirror
  // corporate_events.event_type (which is TEXT, not a native enum) — validated at the API.
  eventType String @map("event_type")

  // Lead time in days. Default 1 (the point is lead time — we never fire ON the event day).
  daysBefore Int @default(1) @map("days_before")

  // Lifecycle. active=false ⇔ paused (the PATCH endpoint toggles this and nothing else).
  active      Boolean   @default(true)
  lastFiredAt DateTime? @map("last_fired_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock  Stock                @relation(fields: [stockId], references: [id], onDelete: Cascade)
  events EventReminderEvent[]

  // One reminder per (user, stock, eventType) — the semantic bind is unique per user, so a
  // POST for an existing pair updates it (idempotent) rather than piling up duplicates.
  @@unique([userId, stockId, eventType], name: "event_reminder_unique")
  @@index([userId, createdAt(sort: Desc)]) // the user's reminders list, newest first
  @@index([active]) // the daily eval pass scans ACTIVE reminders
  @@index([stockId])
  @@map("event_reminders")
}

// The FIRED log — one row per reminder per resolved event OCCURRENCE. The email drain reads
// delivered=false rows and sends via the SAME mailer alerts use (delivered flips true on a
// confirmed send). `resolvedEventDate` is the DEDUPE key: fire once per (reminder,
// occurrence date) — a re-eval on the same day never double-sends, while a genuinely new
// date (a reschedule) is a new occurrence that may fire again. Mirrors AlertEvent; user_id
// + stock_id are denormalised so the IDOR-scoped log read needs no join.
model EventReminderEvent {
  id                String   @id @default(uuid())
  reminderId        String   @map("reminder_id")
  userId            String   @map("user_id")
  stockId           String   @map("stock_id")
  eventType         String   @map("event_type") // denormalised (the reminder's type at fire)
  resolvedEventDate DateTime @map("resolved_event_date") @db.Date // the occurrence reminded for
  firedAt           DateTime @default(now()) @map("fired_at")
  delivered         Boolean  @default(false) // email flips this true after a confirmed send
  createdAt         DateTime @default(now()) @map("created_at")

  reminder EventReminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock    Stock         @relation(fields: [stockId], references: [id], onDelete: Cascade)

  // Hard dedupe: one fired row per reminder per occurrence date (belt-and-braces with the
  // eval's own pre-check — a race can never double-insert for the same occurrence).
  @@unique([reminderId, resolvedEventDate], name: "event_reminder_event_occurrence")
  @@index([userId, firedAt(sort: Desc)]) // the user's reminder feed (in-app surface)
  @@index([reminderId])
  @@index([delivered]) // the email drain scans undelivered rows
  @@map("event_reminder_events")
}
